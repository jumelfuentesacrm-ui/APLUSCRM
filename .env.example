# ─────────────────────────────────────────────────────────────────
# A+ CRM — Environment Variables
# Copy to .env.local for local dev, add to Vercel for production.
# Every client gets their own Supabase project + Vercel project.
# The NEXT_PUBLIC_BRAND_* block is the ONLY thing that changes per client.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
# Get these from: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Web Push (VAPID) ──────────────────────────────────────────────
# Generate once per Vercel project:
#   npx web-push generate-vapid-keys
# Public key also goes in admin.js (applicationServerKey)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (optional — only if loyalty card payments are enabled) ─
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Brand / Rebranding (change these per client) ──────────────────
NEXT_PUBLIC_BRAND_NAME=A+ CRM
NEXT_PUBLIC_BUSINESS_NAME=A+ Accounting & Business Services
NEXT_PUBLIC_PHONE=+17875551234
NEXT_PUBLIC_WHATSAPP=17875551234
NEXT_PUBLIC_EMAIL=hello@apluscrm.com
NEXT_PUBLIC_LOCATION=Puerto Rico
NEXT_PUBLIC_WEBSITE=https://apluscrm.com
NEXT_PUBLIC_TAX_RATE=0.115

# ── Brand colors (optional — gold accent only for now) ────────────
NEXT_PUBLIC_COLOR_GOLD=#b8975a

# ── Fonts (optional — override per client) ────────────────────────
# Must be available via Google Fonts or system fonts
NEXT_PUBLIC_FONT_BODY=Inter,ui-sans-serif,system-ui,sans-serif
NEXT_PUBLIC_FONT_HEADING=Cormorant Garamond,serif
